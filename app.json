{
  "expo": {
    "name": "stuby",
    "slug": "stuby",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/defaultProfile.png",
    "scheme": "stuby",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/defaultProfile.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ],
      "package": "com.shandler.stuby"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/defaultProfile.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/defaultProfile.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-audio",
      "expo-asset",
      "expo-font",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "fonts": [
      {
        "asset": "./assets/font/Chunko-Bold.otf"
      }
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "1578e491-d790-4e1a-8a5a-ea6723e31134"
      }
    }
  }
}
